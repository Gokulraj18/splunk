pipeline {
    agent any

    environment {
        APP_NAME = 'splunk-crud-app'
        MYSQL_CONTAINER = 'mysql-db'
        MYSQL_ROOT_PASSWORD = 'Ggop1810'
        MYSQL_DB = 'Splunk'
        DOCKER_NETWORK = 'app-network'
        SPRING_PROFILE = 'prod'
    }

    stages {
        stage('Clean Workspace') {
            steps {
                echo "Cleaning workspace..."
                deleteDir()
            }
        }

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Gokulraj18/splunk.git'
            }
        }

        stage('Build Spring Boot App') {
            steps {
                echo "Building Spring Boot app..."
                sh './mvnw clean package -DskipTests' // skip tests to avoid Jenkins failure
            }
        }

        stage('Docker Setup') {
            steps {
                echo "Creating Docker network if not exists..."
                sh """
                docker network inspect ${DOCKER_NETWORK} >/dev/null 2>&1 || docker network create ${DOCKER_NETWORK}
                """

                echo "Starting MySQL container..."
                sh """
                docker ps -a | grep ${MYSQL_CONTAINER} || docker run -d \\
                    --name ${MYSQL_CONTAINER} \\
                    --network ${DOCKER_NETWORK} \\
                    -e MYSQL_ROOT_PASSWORD=${MYSQL_ROOT_PASSWORD} \\
                    -e MYSQL_DATABASE=${MYSQL_DB} \\
                    -p 3306:3306 \\
                    mysql:8.1
                """
            }
        }

        stage('Docker Build & Deploy App') {
            steps {
                echo "Building and deploying Spring Boot Docker container..."
                sh """
                # Remove old container if exists
                docker rm -f ${APP_NAME} >/dev/null 2>&1 || true

                # Build app Docker image
                docker build -t ${APP_NAME} .

                # Run the app container
                docker run -d \\
                    --name ${APP_NAME} \\
                    --network ${DOCKER_NETWORK} \\
                    -e SPRING_DATASOURCE_URL=jdbc:mysql://${MYSQL_CONTAINER}:3306/${MYSQL_DB} \\
                    -e SPRING_DATASOURCE_USERNAME=root \\
                    -e SPRING_DATASOURCE_PASSWORD=${MYSQL_ROOT_PASSWORD} \\
                    -e SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect \\
                    -p 8082:8080 \\
                    ${APP_NAME}
                """
            }
        }

        stage('Verify Deployment') {
            steps {
                echo "Checking app status..."
                sh 'docker ps | grep splunk-crud-app'
            }
        }
    }

    post {
        success {
            echo "Deployment successful!"
        }
        failure {
            echo "Pipeline failed. Check logs above for details."
        }
    }
}
