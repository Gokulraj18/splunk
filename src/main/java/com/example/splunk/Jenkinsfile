pipeline {
    agent any

    environment {
        IMAGE_NAME = "splunk-crud-app"
        MYSQL_CONTAINER = "mysql-db"
        APP_CONTAINER = "splunk-crud-app"
    }

    stages {
        stage('Build') {
            steps {
                sh './mvnw clean package -DskipTests'
            }
        }

        stage('Test') {
            steps {
                sh './mvnw test'
            }
        }

        stage('Docker Build & Deploy') {
            steps {
                // Build Docker image
                sh "docker build -t ${IMAGE_NAME} ."

                // Stop and remove old container
                sh "docker rm -f ${APP_CONTAINER} || true"

                // Run new container
                sh """
                docker run -d \
                  --name ${APP_CONTAINER} \
                  --network app-network \
                  -e SPRING_DATASOURCE_URL=jdbc:mysql://${MYSQL_CONTAINER}:3306/Splunk \
                  -e SPRING_DATASOURCE_USERNAME=root \
                  -e SPRING_DATASOURCE_PASSWORD=Ggop1810 \
                  -e SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect \
                  -p 8082:8080 \
                  ${IMAGE_NAME}
                """
            }
        }
    }
}
