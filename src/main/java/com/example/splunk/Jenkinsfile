pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK21'
    }

    environment {
        IMAGE_NAME = "splunk-crud-app"
        CONTAINER_NAME = "splunk-app"
        SPLUNK_HEC_URL = 'https://localhost:8088/services/collector'
    }

    stages {
        stage('Clone Repository') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Stop & Remove Old Container') {
            steps {
                sh """
                    docker stop ${CONTAINER_NAME} || true
                    docker rm ${CONTAINER_NAME} || true
                    docker rmi ${IMAGE_NAME} || true
                """
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t ${IMAGE_NAME} -f src/main/java/com/example/splunk/Dockerfile .'
            }
        }

        stage('Run Container & Debug') {
            steps {
                withCredentials([string(credentialsId: 'SPLUNK_HEC_TOKEN', variable: 'HEC_TOKEN')]) {
                    // Security note: Jenkins will still mask this as ****
                    sh "echo 'Deploying with token: ${HEC_TOKEN}'"
                    
                    sh '''
                        docker run -d -p 8081:8080 --name ${CONTAINER_NAME} \
                        -e SPLUNK_HEC_URL=${SPLUNK_HEC_URL} \
                        -e SPLUNK_HEC_TOKEN=${HEC_TOKEN} \
                        ${IMAGE_NAME}
                    '''
                }
            }
        }

        stage('Send Test Log to Splunk') {
            steps {
                withCredentials([string(credentialsId: 'SPLUNK_HEC_TOKEN', variable: 'HEC_TOKEN')]) {
                    sh '''
                        echo "Testing connection to ${SPLUNK_HEC_URL}..."
                        curl -i -k "${SPLUNK_HEC_URL}" \
                        -H "Authorization: Splunk ${HEC_TOKEN}" \
                        -H "Content-Type: application/json" \
                        -d '{"event": "Jenkins pipeline test", "sourcetype": "_json"}'
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'CI/CD Pipeline Completed Successfully'
        }
        failure {
            echo 'Pipeline Failed - Check Splunk Token permissions or Network'
        }
    }
}
